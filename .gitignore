# =============================================================================
# .gitignore — HCPA Project
# =============================================================================

# ---- Data / datasets (NEVER commit) ----
data/
hcpa-all-images/
all-tfrec/
all_processed/
all_processed.zip
archive.zip
core/
*.tfrec
*.rsf
*.rsf@

# ---- Results / outputs (NEVER commit) ----
**/results/
results*/
**/logs/
*.err
*.out

# ---- Generated plots and tables ----
paper_plots/
stats_plots/
plots/
plots_all/*.csv
plots_all/*.png
clean_hcpa_pytorch/

# ---- CSV result files at root level ----
*.csv

# ---- Caches ----
triton_cache/
torchinductor_cache/
tfdata_cache/
.cache/
__pycache__/
.ipynb_checkpoints/

# ---- Model weights / checkpoints ----
*.h5
*.hdf5
*.pth
*.ckpt
*.ckpt.*
*.keras/
.keras/
checkpoints/

# ---- Virtual environments ----
.venv/
.env/
env/
env_graph/
env_arm/
venv/
ENV/
env.bak/
venv.bak/
**/.venv/
**/.env/
**/env/

# ---- Notebooks (excluded per user request) ----
*.ipynb

# ---- Accidental / stray files ----
=0.9,

# ---- Core dumps ----
core
**/core

# ---- Python standard ignores ----
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# PyInstaller
*.manifest
*.spec

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage reports
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
.pytest_cache/
cover/

# Translations
*.mo
*.pot

# Django stuff
*.log
local_settings.py
db.sqlite3
db.sqlite3-journal

# Flask stuff
instance/
.webassets-cache

# Scrapy stuff
.scrapy

# Sphinx documentation
docs/_build/

# PyBuilder
.pybuilder/
target/

# IPython
profile_default/
ipython_config.py

# pipenv / poetry / pdm
.pdm.toml
__pypackages__/

# Celery stuff
celerybeat-schedule
celerybeat.pid

# SageMath parsed files
*.sage.py

# Spyder / Rope project settings
.spyderproject
.spyproject
.ropeproject

# mkdocs documentation
/site

