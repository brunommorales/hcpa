# Apptainer definition generated from pytorch_opt/Dockerfile
# Build hint: export SINGULARITY_DOCKER_USERNAME=$oauthtoken and SINGULARITY_DOCKER_PASSWORD=<NGC_API_KEY> before `apptainer build --fakeroot pytorch_opt.sif Apptainer.def`

Bootstrap: docker
From: nvcr.io/nvidia/pytorch:24.11-py3
# To align with driver R580+, switch to: From: nvcr.io/nvidia/pytorch:25.09-py3

%labels
    Maintainer bmmorales
    App pytorch_opt

%files
    requirements-ngc.txt /tmp/requirements-ngc.txt

%post
    set -eux
    if [ -f /etc/pip/constraint.txt ]; then
        C="-c /etc/pip/constraint.txt"
    else
        C=""
    fi
    python -m pip install --upgrade pip
    python -m pip install -r /tmp/requirements-ngc.txt ${C}
    # Enable DALI if/when needed:
    # python -m pip install --extra-index-url https://developer.download.nvidia.com/compute/redist nvidia-dali-cuda120
    rm -rf /root/.cache/pip
    mkdir -p /workspace
    chmod 777 /workspace

%environment
    export KERAS_BACKEND=torch

%runscript
    exec /bin/bash "$@"
