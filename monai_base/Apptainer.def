# Apptainer definition for monai_base (PyTorch/MONAI) — alinhado ao monai_opt (DALI desativado).

Bootstrap: docker
From: nvcr.io/nvidia/pytorch:24.12-py3

%labels
    Maintainer bmmorales
    App monai_base

%files
    requirements.txt /tmp/requirements.txt

%post
    set -eux
    python -m pip install --upgrade pip
    python -m pip install -r /tmp/requirements.txt
    rm -rf /root/.cache/pip
    mkdir -p /workspace
    chmod 777 /workspace

%environment
    export PYTHONPATH=/workspace
    export TF_CPP_MIN_LOG_LEVEL=1
    export TORCH_HOME=/workspace/.cache/torch
    export TORCHINDUCTOR_CACHE_DIR=/workspace/.cache/inductor
    export TRANSFORMERS_CACHE=/workspace/.cache/hf
    export HF_HOME=/workspace/.cache/hf

%runscript
    exec /bin/bash "$@"
